root = true

# Defaults for every file.
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# C / C++ sources and headers (kept in sync with .clang-format: 4-space, LF).
[*.{c,cc,cpp,cxx,h,hh,hpp,hxx,inl,ipp}]
indent_size = 4

# PowerShell.
[*.{ps1,psm1,psd1}]
indent_size = 4

# CMake + plain text.
[*.{cmake,txt}]
indent_size = 4
[CMakeLists.txt]
indent_size = 4

# YAML / JSON / data (clangd, clang-tidy, clang-format, presets, gitignore-style).
[*.{json,yaml,yml}]
indent_size = 2

# Markdown: trailing spaces can be meaningful (hard line breaks), so preserve them.
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# Generated dependency metadata lives in RE-UE4SS/ — leave it alone.
[RE-UE4SS/**]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
